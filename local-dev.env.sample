# Local-only: append backend lines to backend/.env and frontend lines to frontend/.env
# Requires a JDK on PATH (java -version) for Firebase emulators.
# Then run: Terminal 1 — npx firebase emulators:start --only auth,firestore (from repo root)
#           Terminal 2 — cd backend && npm run dev
#           Terminal 3 — cd frontend && npx expo start

# --- backend/.env ---
USE_FIREBASE_EMULATOR=true

# --- frontend/.env (Expo loads this automatically) ---
EXPO_PUBLIC_USE_FIREBASE_EMULATOR=1
