# Copy this file to .env and fill in your Supabase credentials.
# Find these in: Supabase Dashboard → Settings → API

PORT=5000

# ─── Supabase ────────────────────────────────────────────────────────────────

# Your Supabase project URL  (e.g. https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service Role key — keep this SECRET, backend-only
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Anon (public) key — used for server-side web password verification
# This is safe to commit to .env.example but NOT to .env
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ─── Face verification token ─────────────────────────────────────────────────

# HMAC-SHA256 signing secret for face verification tokens (2-min TTL tokens)
# Generate with: node -e "const c=require('crypto');console.log(c.randomBytes(32).toString('hex'))"
# MUST be kept secret — rotate this if it leaks
FACE_TOKEN_SECRET=CHANGE_ME_GENERATE_WITH_NODE_CRYPTO

# Cosine-similarity threshold for an ArcFace face match (0–1). Higher = stricter
# (fewer false accepts, more false rejects). Default 0.55 (strict). Calibrate
# against your enrolled users by sweeping ~0.45–0.65. Optional — omit to use default.
FACE_MATCH_THRESHOLD=0.55

# ─── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins
CORS_ORIGIN=https://YOUR_NETLIFY_APP.netlify.app,http://localhost:19006,http://localhost:8081,http://localhost:3000
