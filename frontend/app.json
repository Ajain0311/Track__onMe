{
  "expo": {
    "name": "AttendTrack",
    "slug": "attendtrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#06060f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.attendtrack.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06060f"
      },
      "package": "com.attendtrack.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AttendTrack to access your camera for face recognition."
        }
      ]
    ]
  }
}
