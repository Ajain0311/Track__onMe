{
  "expo": {
    "name": "AttendTrack",
    "slug": "attendtrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#06060f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.attendtrack.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06060f"
      },
      "package": "com.attendtrack.app",
      "kotlinVersion": "1.9.25",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AttendTrack to access your camera for face recognition."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow AttendTrack to use your location to verify your work location."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2c27442f-398d-4b20-b9f6-08c817e494c4"
      }
    },
    "owner": "ajain0311"
  }
}
